    _type.purpose                 Measurand
    _type.source                  Derived
    _type.container               Matrix
    _type.dimension               '[3]'
    _type.contents                Real
    _units.code                   None
    _method.expression
;
     With  m  as  model_site

    _model_site.Cartn_xyz =  _atom_sites_Cartn_transform.matrix * m.fract_xyz
;


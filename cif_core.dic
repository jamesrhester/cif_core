    _name.category_id             GEOM
    _name.object_id               GEOM_HBOND

    loop_
      _category_key.name
         '_geom_hbond.atom_site_label_D'
         '_geom_hbond.atom_site_label_H'
         '_geom_hbond.atom_site_label_A'
         '_geom_hbond.site_symmetry_D'
         '_geom_hbond.site_symmetry_H'
